        {
          "@type": "Question",
          "name": "Do I pay anything for White Card home health services?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Approved beneficiaries generally pay nothing out of pocket for covered, physician-ordered home health services."
          }
        }
